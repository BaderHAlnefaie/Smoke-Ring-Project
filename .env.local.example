# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real secrets.

# ---- Supabase ----
# Find these at: https://supabase.com/dashboard/project/<project-id>/settings/api

# Public values — sent to the browser. Must be prefixed NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — bypasses Row-Level Security. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site ----
# Public origin used to build payment callback URLs (no trailing slash).
# Example: http://localhost:3000 in dev, https://smokering.example in prod.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Auth ----
# Set to "true" to use email magic-link instead of phone OTP.
# Useful in dev when SMS to Saudi numbers is unreliable.
AUTH_FALLBACK_EMAIL=true

# ---- Moyasar (test mode) ----
# Get these at: https://dashboard.moyasar.com/settings/api
MOYASAR_PUBLISHABLE_KEY=pk_test_
MOYASAR_SECRET_KEY=sk_test_
# Shared secret configured in the Moyasar dashboard for the webhook endpoint.
MOYASAR_WEBHOOK_SECRET=

# ---- Notifications (optional) ----
# Twilio credentials for "your order is ready" SMS. If unset, notifications are
# still recorded in the DB and logged — SMS just isn't sent.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
